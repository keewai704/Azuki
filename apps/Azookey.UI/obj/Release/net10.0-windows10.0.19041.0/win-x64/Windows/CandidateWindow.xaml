<Window
    x:Class="Azookey.UI.Windows.CandidateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent">
        <Border x:ConnectionId='2'
            x:Name="RootBorder"
            Padding="8"
            Background="#FFFDFDFD"
            BorderBrush="#FFD9D9D9"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel>
                <StackPanel x:ConnectionId='3' x:Name="CandidateListPanel" Spacing="2">
                    <Border x:ConnectionId='5' x:Name="Row1" Padding="8,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:ConnectionId='18' x:Name="IndexText1" FontSize="12" Foreground="#FF666666" />
                            <TextBlock x:ConnectionId='19' x:Name="CandidateText1" Foreground="#FF202020" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border x:ConnectionId='6' x:Name="Row2" Padding="8,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:ConnectionId='16' x:Name="IndexText2" FontSize="12" Foreground="#FF666666" />
                            <TextBlock x:ConnectionId='17' x:Name="CandidateText2" Foreground="#FF202020" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border x:ConnectionId='7' x:Name="Row3" Padding="8,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:ConnectionId='14' x:Name="IndexText3" FontSize="12" Foreground="#FF666666" />
                            <TextBlock x:ConnectionId='15' x:Name="CandidateText3" Foreground="#FF202020" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border x:ConnectionId='8' x:Name="Row4" Padding="8,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:ConnectionId='12' x:Name="IndexText4" FontSize="12" Foreground="#FF666666" />
                            <TextBlock x:ConnectionId='13' x:Name="CandidateText4" Foreground="#FF202020" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border x:ConnectionId='9' x:Name="Row5" Padding="8,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:ConnectionId='10' x:Name="IndexText5" FontSize="12" Foreground="#FF666666" />
                            <TextBlock x:ConnectionId='11' x:Name="CandidateText5" Foreground="#FF202020" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border x:ConnectionId='4'
                    x:Name="FooterBorder"
                    Margin="0,8,0,0"
                    Padding="8,6,8,0"
                    BorderBrush="#FFE7E7E7"
                    BorderThickness="0,1,0,0">
                    <TextBlock Text="Azookey" FontSize="12" Foreground="#FF202020" Opacity="0.7" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>

