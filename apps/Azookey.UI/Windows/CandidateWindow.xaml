<Window
    x:Class="Azookey.UI.Windows.CandidateWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent">
        <Border
            x:Name="RootBorder"
            Padding="8"
            Background="#FFFDFDFD"
            BorderBrush="#FFD9D9D9"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel>
                <StackPanel x:Name="CandidateListPanel" Spacing="2">
                    <Border x:Name="Row1" Padding="8,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="IndexText1" FontSize="12" Foreground="#FF666666" />
                            <TextBlock x:Name="CandidateText1" Foreground="#FF202020" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="Row2" Padding="8,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="IndexText2" FontSize="12" Foreground="#FF666666" />
                            <TextBlock x:Name="CandidateText2" Foreground="#FF202020" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="Row3" Padding="8,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="IndexText3" FontSize="12" Foreground="#FF666666" />
                            <TextBlock x:Name="CandidateText3" Foreground="#FF202020" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="Row4" Padding="8,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="IndexText4" FontSize="12" Foreground="#FF666666" />
                            <TextBlock x:Name="CandidateText4" Foreground="#FF202020" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                    <Border x:Name="Row5" Padding="8,6" CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="IndexText5" FontSize="12" Foreground="#FF666666" />
                            <TextBlock x:Name="CandidateText5" Foreground="#FF202020" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border
                    x:Name="FooterBorder"
                    Margin="0,8,0,0"
                    Padding="8,6,8,0"
                    BorderBrush="#FFE7E7E7"
                    BorderThickness="0,1,0,0">
                    <TextBlock Text="Azookey" FontSize="12" Foreground="#FF202020" Opacity="0.7" />
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
