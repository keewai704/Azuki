<pages:SettingsPageBase
    x:Class="Azookey.Settings.Pages.UserDictionaryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:Azookey.Settings.Pages">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="1040"
            Padding="24,24,24,40"
            HorizontalAlignment="Stretch">
            <StackPanel Spacing="24">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="ユーザー辞書" />

                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="辞書項目" />
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="OnAddDictionaryEntryClick" Content="追加" />
                                <Button Click="OnEditDictionaryEntryClick" Content="編集" />
                                <Button Click="OnRemoveDictionaryEntryClick" Content="削除" />
                                <Button Click="OnSaveDictionaryClick" Content="保存" />
                            </StackPanel>
                            <ListView
                                x:Name="dictionaryEntriesList"
                                MaxHeight="440"
                                SelectionMode="Single" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</pages:SettingsPageBase>
