<pages:SettingsPageBase
    x:Class="Azookey.Settings.Pages.DebugPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:Azookey.Settings.Pages"
    xmlns:controls="using:Azookey.Settings.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="1040"
            Padding="24,24,24,40"
            HorizontalAlignment="Stretch">
            <StackPanel Spacing="24">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="デバッグ" />

                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="診断" />
                    <controls:SettingsRow Description="サーバーログをファイルに出力します。" Header="サーバーログを有効にする" Icon="&#xE7BA;">
                        <controls:SettingsRow.ActionContent>
                            <ToggleSwitch x:Name="serverLogEnabledSwitch" Toggled="OnDebugSettingChanged" />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                    <controls:SettingsRow Description="サーバーログの詳細度を選択します。" Header="サーバーログレベル" Icon="&#xE9D9;">
                        <controls:SettingsRow.ActionContent>
                            <ComboBox x:Name="serverLogLevelBox" MinWidth="200" SelectionChanged="OnServerLogLevelSelectionChanged" />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                    <controls:SettingsRow Description="サーバークラッシュ時にトレースを出力します。" Header="クラッシュトレースを有効にする" Icon="&#xE814;">
                        <controls:SettingsRow.ActionContent>
                            <ToggleSwitch x:Name="serverCrashTraceEnabledSwitch" Toggled="OnDebugSettingChanged" />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                    <controls:SettingsRow Description="現在の設定でサーバーを再起動します。" Header="サーバーを再起動" Icon="&#xE777;">
                        <controls:SettingsRow.ActionContent>
                            <Button Click="OnRestartServerClick" Content="再起動" />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</pages:SettingsPageBase>
