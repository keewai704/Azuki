<pages:SettingsPageBase
    x:Class="Azookey.Settings.Pages.InputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:Azookey.Settings.Pages"
    xmlns:controls="using:Azookey.Settings.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="1040"
            Padding="24,24,24,40"
            HorizontalAlignment="Stretch">
            <StackPanel Spacing="24">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="入力" />

                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="入力方式" />
                    <controls:SettingsRow Description="句読点の入力スタイルを選択します。" Header="句読点" Icon="&#xE8C8;">
                        <controls:SettingsRow.ActionContent>
                            <ComboBox x:ConnectionId='5' x:Name="punctuationStyleBox" MinWidth="240"                                       />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                    <controls:SettingsRow Description="記号の入力スタイルを選択します。" Header="記号" Icon="&#xE8FD;">
                        <controls:SettingsRow.ActionContent>
                            <ComboBox x:ConnectionId='4' x:Name="symbolStyleBox" MinWidth="240"                                       />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                    <controls:SettingsRow Description="スペースキー入力の扱いを選択します。" Header="スペース入力" Icon="&#xE8A5;">
                        <controls:SettingsRow.ActionContent>
                            <ComboBox x:ConnectionId='3' x:Name="spaceInputBox" MinWidth="240"                                       />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                    <controls:SettingsRow Description="テンキー入力の扱いを選択します。" Header="テンキー入力" Icon="&#xE8EF;">
                        <controls:SettingsRow.ActionContent>
                            <ComboBox x:ConnectionId='2' x:Name="numpadInputBox" MinWidth="240"                                       />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</pages:SettingsPageBase>

