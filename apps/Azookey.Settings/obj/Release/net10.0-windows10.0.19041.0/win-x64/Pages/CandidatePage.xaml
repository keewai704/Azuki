<pages:SettingsPageBase
    x:Class="Azookey.Settings.Pages.CandidatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:Azookey.Settings.Pages"
    xmlns:controls="using:Azookey.Settings.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="1040"
            Padding="24,24,24,40"
            HorizontalAlignment="Stretch">
            <StackPanel Spacing="24">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="候補" />

                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="候補表示" />
                    <controls:SettingsRow Description="スペース入力の直後に候補ウィンドウを表示します。" Header="スペース後に候補を表示" Icon="&#xE8FD;">
                        <controls:SettingsRow.ActionContent>
                            <ToggleSwitch x:ConnectionId='2' x:Name="showCandidateWindowAfterSpaceSwitch"                                                  />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</pages:SettingsPageBase>

