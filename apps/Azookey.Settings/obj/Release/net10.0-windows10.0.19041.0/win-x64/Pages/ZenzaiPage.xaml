<pages:SettingsPageBase
    x:Class="Azookey.Settings.Pages.ZenzaiPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pages="using:Azookey.Settings.Pages"
    xmlns:controls="using:Azookey.Settings.Controls">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <Grid
            MaxWidth="1040"
            Padding="24,24,24,40"
            HorizontalAlignment="Stretch">
            <StackPanel Spacing="24">
                <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="Zenzai" />

                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="モデル" />
                    <controls:SettingsRow Description="変換候補に Zenzai を使います。" Header="有効" Icon="&#xE7BA;">
                        <controls:SettingsRow.ActionContent>
                            <ToggleSwitch x:ConnectionId='7' x:Name="zenzaiEnableSwitch"                                  />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                    <controls:SettingsRow Description="推論に使うモデルを選択します。" Header="モデル" Icon="&#xE8B8;">
                        <controls:SettingsRow.ActionContent>
                            <ComboBox x:ConnectionId='6' x:Name="zenzaiModelBox" MinWidth="280"                                            />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                    <controls:SettingsRow Description="推論に使うバックエンドを選択します。" Header="バックエンド" Icon="&#xE9D9;">
                        <controls:SettingsRow.ActionContent>
                            <ComboBox x:ConnectionId='5' x:Name="zenzaiBackendBox" MinWidth="180"                                              />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="プロファイル" />
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="プロファイル" />
                            <TextBox x:ConnectionId='4'
                                x:Name="zenzaiProfileBox"
                                AcceptsReturn="True"
                                                              
                                MinHeight="180"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="実行環境" />
                    <controls:SettingsRow Description="CPU バックエンドの利用可否です。" Header="CPU" Icon="&#xE7F8;">
                        <controls:SettingsRow.ActionContent>
                            <TextBlock x:ConnectionId='3' x:Name="cpuAvailabilityText" VerticalAlignment="Center" />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                    <controls:SettingsRow Description="Vulkan バックエンドの利用可否です。" Header="Vulkan" Icon="&#xE7F8;">
                        <controls:SettingsRow.ActionContent>
                            <TextBlock x:ConnectionId='2' x:Name="vulkanAvailabilityText" VerticalAlignment="Center" />
                        </controls:SettingsRow.ActionContent>
                    </controls:SettingsRow>
                </StackPanel>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</pages:SettingsPageBase>

